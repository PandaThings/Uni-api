generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id        String       @id // Will be the external IDP ID
  email     String       @unique
  name      String?
  avatarUrl String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projects    Project[]    // Projects they own
  memberships Membership[] // Projects they are a member of

  @@map("users")
}

model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String
  projectId String   @db.Uuid
  role      String   @default("member") // owner, admin, member
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
  @@map("memberships")
}

model Project {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String    // Foreign key to User
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id])
  memberships Membership[]
  apiKeys     ApiKey[]
  memories    Memory[]
  requests    Request[]

  @@index([ownerId])
  @@map("projects")
}

model ApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  keyHash      String    @unique // SHA-256
  prefix       String    // First 12 chars: uni_xxxxxxxx
  computeUnits Int       @default(500)
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

model Memory {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  summary       String
  embeddingText String
  // pgvector extension mapping
  embedding     Unsupported("vector(384)")?
  category      String
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("memories")
}

model Request {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  prompt       String
  answer       String
  model        String
  inputTokens  Int
  outputTokens Int
  cost         Float
  latencyMs    Int
  accuracy     Float
  completeness Float
  reasoning    Float
  security     Float
  overallScore Float
  contextUsed  Boolean
  repaired     Boolean   @default(false)
  createdAt    DateTime  @default(now())

  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("requests")
}
